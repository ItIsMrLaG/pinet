AddTup(tup) >< S(y) =>
    tup ~ (r, x),
    AddTup((w, x)) ~ y,
    r ~ S(w);

AddTup(tup) >< Z() =>
    tup ~ (r, x),
    r ~ x;

MulTup(tup) >< S(y) =>
    tup ~ (r, x),
    Dup(x1, x2) ~ x,
    MulTup((w, x1)) ~ y,
    AddTup((r, w)) ~ x2;

MulTup(tup) >< Z() =>
    tup ~ (r, x),
    r ~ Z(),
    x ~ Eraser();

a ~ S(S(S(Z())));
b ~ S(S(S(Z())));
MulTup((r, a)) ~ b;
r;
